# ========================
# GOOGLE OAUTH - PARA DESARROLLO LOCAL
# ========================
# Para que funcionen los botones de Google, debes:
# 1. Ir a https://console.cloud.google.com/
# 2. Crear un proyecto y obtener tus credenciales
# 3. Reemplazar los valores debajo con tus credenciales reales
# 4. Renombrar este archivo a .env o copiar los valores al .env existente

# Ejemplo con credenciales reales (REEMPLAZA ESTOS VALORES):
GOOGLE_CLIENT_ID=tu_client_id_real_aqui
GOOGLE_CLIENT_SECRET=tu_client_secret_real_aqui

# Valores para desarrollo si aún no tienes credenciales reales:
# GOOGLE_CLIENT_ID=placeholder_client_id_local
# GOOGLE_CLIENT_SECRET=placeholder_client_secret_local

# ========================
# FLASK
# ========================
SECRET_KEY=clave_super_secreta

# ========================
# MYSQL (DOCKER)
# ========================
DB_HOST=mysql
DB_PORT=3306
DB_NAME=san_vicentino_db
DB_USER=usuario_app
DB_PASSWORD=password_app
